{#=====================================================
  Flash messages component
  - Displays a list of flash messages
=====================================================#}

{% with messages = get_flashed_messages(with_categories=true) %}
    {% if messages %}

        <div id="messages">
            {% for category, message in messages %}

                <div class="message {{ category }}">
                    {{ message }}
                </div>

            {% endfor %}
        </div>

    {% endif %}
{% endwith %}


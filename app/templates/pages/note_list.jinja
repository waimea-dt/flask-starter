{#=====================================================
  Home page
=====================================================#}

{% extends 'pages/base.jinja' %}


{% block content %}

    <section id="notes">

        {% for note in notes %}

            <article class="note {{ 'pinned' if note.pinned }}">

                <header>
                    <h3>{{ note.title }}</h3>
                    {{ "📌" if note.pinned }}
                </header>

                <p>{{ note.body | paragraphs }}</p>

                <footer>
                    Created on {{ note.created | local | format }}
                </footer>

            </article>

        {% else %}

            <p>No Notes!</p>

        {% endfor %}

    </section>

{% endblock %}

